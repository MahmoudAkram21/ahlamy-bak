# MySQL - adjust values to your setup
DATABASE_URL="mysql://root:@localhost:3306/ahlamy_db"

NODE_ENV=development

PORT=5000

JWT_SECRET=your-super-secret-jwt-key-change-this

BCRYPT_SALT_ROUNDS=10
JWT_EXPIRES_IN=7d
SESSION_COOKIE_SAME_SITE=lax
SESSION_COOKIE_SECURE=false

CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://ahlamy-dashboard.vercel.app
# Optional comma-separated regex patterns for preview deployments.
# Example for one Vercel dashboard project:
# CORS_ORIGIN_PATTERNS=^https://ahlamy-dashboard(-git-[a-z0-9-]+)?\\.vercel\\.app$

NEXT_PUBLIC_APP_URL=http://localhost:3000

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
