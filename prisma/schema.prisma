generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  profile   Profile?

  @@map("users")
}

model Profile {
  id                    String        @id
  email                 String        @unique
  fullName              String?       @map("full_name")
  role                  Role          @default(dreamer)
  avatarUrl             String?       @map("avatar_url")
  bio                   String?
  city                  String        @default("Cairo") @db.VarChar(100)
  countryCode           String        @default("EG") @map("country_code") @db.VarChar(2)
  isAvailable           Boolean       @default(true) @map("is_available")
  totalInterpretations  Int           @default(0) @map("total_interpretations")
  rating                Decimal       @default(0.00) @db.Decimal(3, 2)
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")
  deletedAt             DateTime?     @map("deleted_at")
  adminLogs             AdminLog[]
  chatMessages          ChatMessage[]
  dreamsAsDreamer       Dream[]       @relation("DreamerDreams")
  payments              Payment[]
  notifications         Notification[]
  user                  User          @relation(fields: [id], references: [id], onDelete: Cascade)
  requestsAsDreamer     Request[]     @relation("DreamerRequests")
  requestsAsInterpreter Request[]     @relation("InterpreterRequests")

  @@index([deletedAt])
  @@map("profiles")
}

model Dream {
  id             String      @id @default(uuid())
  dreamerId      String      @map("dreamer_id")
  title          String
  description    String      @db.Text
  dreamDate      DateTime?   @map("dream_date")
  mood           String?
  metadata       Json?
  isFeatured     Boolean     @default(false) @map("is_featured")
  featuredAt     DateTime?   @map("featured_at")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  deletedAt      DateTime?   @map("deleted_at")

  // Relations
  dreamer      Profile   @relation("DreamerDreams", fields: [dreamerId], references: [id], onDelete: Cascade)
  requests     Request[]

  @@index([dreamerId])
  @@index([deletedAt])
  @@map("dreams")
}

model ChatMessage {
  id          String          @id @default(uuid())
  requestId   String          @map("request_id")
  senderId    String          @map("sender_id")
  content     String?         @db.Text
  messageType ChatMessageType @default(text) @map("message_type")
  audioUrl    String?         @map("audio_url") @db.VarChar(500)
  isRead      Boolean         @default(false) @map("is_read")
  createdAt   DateTime        @default(now()) @map("created_at")
  request     Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
  sender      Profile         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([requestId], map: "chat_messages_request_id_fkey")
  @@index([senderId], map: "chat_messages_sender_id_fkey")
  @@map("chat_messages")
}

model Plan {
  id                String              @id @default(uuid())
  name              String              @unique
  description       String?
  price             Decimal             @db.Decimal(10, 2)
  currency          String              @map("currency") @db.VarChar(3)
  letterQuota       Int                 @map("letter_quota") // Letters allowed for ONE request
  features          Json                @default("[]")
  scope             PlanScope           @default(egypt)
  countryCodes      Json                @default("[]") @map("country_codes")
  isActive          Boolean             @default(true) @map("is_active")
  supportsVoiceNotes Boolean            @default(false) @map("supports_voice_notes")
  voiceNoteMaxSeconds Int?              @map("voice_note_max_seconds")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  deletedAt         DateTime?           @map("deleted_at")
  payments          Payment[]
  requestPurchases  RequestPlanPurchase[]
  requests          Request[]

  @@index([deletedAt])
  @@map("plans")
}

model Payment {
  id                  String               @id @default(uuid())
  userId              String               @map("user_id")
  planId              String               @map("plan_id") // Required - payment is for a plan
  requestId           String               @map("request_id")
  amount              Decimal              @db.Decimal(10, 2)
  currency            String               @db.VarChar(3)
  status              PaymentStatus        @default(pending)
  provider            String?              @map("provider") @db.VarChar(100)
  reference           String?              @map("reference")
  metadata            Json?
  paidAt              DateTime?            @map("paid_at")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  plan                Plan                 @relation(fields: [planId], references: [id], onDelete: Cascade)
  request             Request              @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user                Profile              @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestPurchase RequestPlanPurchase?

  @@index([planId], map: "payments_plan_id_fkey")
  @@index([userId], map: "payments_user_id_fkey")
  @@index([requestId])
  @@map("payments")
}

model RequestPlanPurchase {
  id                  String         @id @default(uuid())
  requestId           String         @unique @map("request_id")
  planId              String         @map("plan_id")
  paymentId           String?        @unique @map("payment_id")
  submissionType      SubmissionType @map("submission_type")
  letterQuota         Int            @map("letter_quota")
  lettersUsed         Int            @default(0) @map("letters_used")
  voiceNoteMaxSeconds Int?           @map("voice_note_max_seconds")
  createdAt           DateTime       @default(now()) @map("created_at")

  request Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  plan    Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  payment Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([planId])
  @@index([paymentId])
  @@map("request_plan_purchases")
}

model Request {
  id                          String              @id @default(uuid())
  dreamId                     String              @map("dream_id")
  dreamerId                   String              @map("dreamer_id")
  interpreterId               String?             @map("interpreter_id")
  planId                      String?             @map("plan_id")
  submissionType              SubmissionType?     @map("submission_type")
  dreamDescriptionText        String?             @map("dream_description_text") @db.Text
  dreamDescriptionAudioUrl    String?             @map("dream_description_audio_url") @db.VarChar(500)
  status                      RequestStatus       @default(draft)
  isSatisfied                 Boolean             @default(false) @map("is_satisfied")
  satisfiedAt                 DateTime?           @map("satisfied_at")
  createdAt                   DateTime            @default(now()) @map("created_at")
  updatedAt                   DateTime            @updatedAt @map("updated_at")
  chatMessages                ChatMessage[]
  planPurchase                RequestPlanPurchase?
  dream                       Dream               @relation(fields: [dreamId], references: [id], onDelete: Cascade)
  dreamer                     Profile             @relation("DreamerRequests", fields: [dreamerId], references: [id], onDelete: Cascade)
  interpreter                 Profile?            @relation("InterpreterRequests", fields: [interpreterId], references: [id])
  plan                        Plan?               @relation(fields: [planId], references: [id], onDelete: SetNull)
  payments                    Payment[]

  @@index([dreamId])
  @@index([dreamerId])
  @@index([interpreterId])
  @@index([planId])
  @@index([status])
  @@unique([dreamId])
  @@map("requests")
}

model AdminLog {
  id         String   @id @default(uuid())
  adminId    String   @map("admin_id")
  action     String
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  details    Json?
  createdAt  DateTime @default(now()) @map("created_at")
  admin      Profile  @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId], map: "admin_logs_admin_id_fkey")
  @@map("admin_logs")
}

model PageContent {
  id          String   @id @default(uuid())
  pageKey     String   @unique @map("page_key") @db.VarChar(100)
  title       String?  @db.VarChar(255)
  content     String   @db.Text
  metadata    Json?
  isPublished Boolean  @default(true) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("page_contents")
}

model Notification {
  id          String           @id @default(uuid())
  userId      String           @map("user_id")
  type        NotificationType
  message     String           @db.VarChar(500)
  isRead      Boolean          @default(false) @map("is_read")
  referenceId String?          @map("reference_id")
  createdAt   DateTime         @default(now()) @map("created_at")
  user        Profile          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([referenceId])
  @@map("notifications")
}

model InterpreterApplication {
  id              String                       @id @default(uuid())
  fullName        String                       @map("full_name") @db.VarChar(255)
  email           String                       @unique @db.VarChar(255)
  phone           String?                      @db.VarChar(50)
  city            String                       @default("Cairo") @db.VarChar(100)
  countryCode     String                       @default("EG") @map("country_code") @db.VarChar(2)
  bio             String?                      @db.Text
  qualifications  String?                      @db.Text
  experienceYears Int                          @default(0) @map("experience_years")
  status          InterpreterApplicationStatus @default(pending)
  notes           String?                      @db.Text
  reviewedAt      DateTime?                    @map("reviewed_at")
  createdAt       DateTime                     @default(now()) @map("created_at")
  updatedAt       DateTime                     @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@map("interpreter_applications")
}

model Review {
  id           String   @id @default(uuid())
  reviewerName String   @map("reviewer_name") @db.VarChar(255)
  content      String   @db.Text
  rating       Int      @default(5)
  source       String?  @db.VarChar(100)
  isFeatured   Boolean  @default(false) @map("is_featured")
  isPublished  Boolean  @default(true) @map("is_published")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([isFeatured, isPublished, createdAt])
  @@map("reviews")
}

model InterpreterMessageTemplate {
  id        String                      @id @default(uuid())
  category  InterpreterTemplateCategory
  content   String                      @db.Text
  sortOrder Int                         @default(0) @map("sort_order")
  isActive  Boolean                     @default(true) @map("is_active")
  createdAt DateTime                    @default(now()) @map("created_at")
  updatedAt DateTime                    @updatedAt @map("updated_at")

  @@index([category, sortOrder])
  @@map("interpreter_message_templates")
}


enum Role {
  dreamer
  interpreter
  admin
  super_admin
}

enum ChatMessageType {
  text
  audio
}

enum PlanScope {
  egypt
  international
  custom
}

enum PaymentStatus {
  pending
  succeeded
  failed
  refunded
  cancelled
}

enum RequestStatus {
  draft
  pending_payment
  paid
  open
  in_progress
  closed
  cancelled
}

enum SubmissionType {
  text
  audio
}

enum InterpreterTemplateCategory {
  opening
  closing
  general
}

enum NotificationType {
  admin_broadcast
  request_message
  request_paid
  request_assigned
  request_status_changed
}

enum InterpreterApplicationStatus {
  pending
  resubmitted
  approved
  rejected
}

